{
  "name": "desk-pet-mac",
  "version": "1.1.0",
  "description": "AI-powered desktop pet for macOS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build-zip": "electron-builder --mac zip",
    "dist": "npm run build && npm run build-zip"
  },
  "build": {
    "appId": "com.deskpet.mac",
    "productName": "DeskPet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.md"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "asar": true,
    "compression": "maximum"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  }
}
